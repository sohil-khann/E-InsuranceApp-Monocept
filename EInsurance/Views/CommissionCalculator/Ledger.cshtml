@model EInsurance.Models.Commission.CommissionLedgerViewModel

@{
    ViewData["Title"] = "My Commission Ledger | Guardian Portal";
}

<style>
    :root {
        --primary: #006b54;
        --primary-light: #22b590;
        --surface: #f4fbf6;
        --surface-container: #eff5f0;
        --on-surface: #1a1b1a;
    }

    body {
        background-color: var(--surface);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .card {
        background: white;
        border-radius: 1rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        overflow: hidden;
    }

    .table-container {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: var(--surface-container);
        padding: 1rem;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        border-bottom: 1px solid #e5e7eb;
        white-space: nowrap;
    }

    td {
        padding: 1rem;
        border-bottom: 1px solid #e5e7eb;
        vertical-align: middle;
    }

    tr:hover {
        background: var(--surface-container);
    }

    .status-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-calculated {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-paid {
        background: #dcfce7;
        color: #166534;
    }

    .pager {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        padding: 1rem;
        border-top: 1px solid #e5e7eb;
        background: white;
    }

    .pager a,
    .pager span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.25rem;
        height: 2.25rem;
        padding: 0 0.75rem;
        border-radius: 9999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.875rem;
        border: 1px solid #e5e7eb;
        background: white;
        color: var(--on-surface);
    }

    .pager .active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .pager .disabled {
        opacity: 0.5;
        pointer-events: none;
    }
</style>

<div class="container mx-auto px-4 py-8">
    <div class="mb-8">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); margin-bottom: 0.5rem;">My Earnings</p>
        <h1 style="font-size: 2.5rem; font-weight: 900; color: var(--on-surface); margin-bottom: 0.5rem;">Commission Ledger</h1>
        <p style="color: #6b7280;">View your complete commission history, payment status, and earnings breakdown.</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
        <div class="card" style="padding: 1.5rem;">
            <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #6b7280; margin-bottom: 0.5rem;">Total Commission</p>
            <p style="font-size: 2rem; font-weight: 900; color: var(--primary-light); margin: 0;">@Model.TotalCommissionAmount.ToString("C")</p>
        </div>

        <div class="card" style="padding: 1.5rem;">
            <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #6b7280; margin-bottom: 0.5rem;">Paid Commissions</p>
            <p style="font-size: 2rem; font-weight: 900; color: #166534; margin: 0;">@Model.PaidCount</p>
        </div>

        <div class="card" style="padding: 1.5rem;">
            <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #6b7280; margin-bottom: 0.5rem;">Pending</p>
            <p style="font-size: 2rem; font-weight: 900; color: #92400e; margin: 0;">@Model.PendingCount</p>
        </div>
    </div>

    <div class="card">
        @if (Model.Ledger.Items.Any())
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Policy</th>
                            <th>Customer</th>
                            <th>Premium</th>
                            <th>Commission</th>
                            <th>Status</th>
                            <th>Calculated Date</th>
                            <th>Paid Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Ledger.Items)
                        {
                            <tr>
                                <td style="font-weight: 600; color: var(--on-surface);">@entry.PolicyNumber</td>
                                <td>@entry.CustomerName</td>
                                <td style="font-weight: 600;">@entry.Premium.ToString("C")</td>
                                <td style="font-weight: 700; color: var(--primary-light);">@entry.CommissionAmount.ToString("C")</td>
                                <td>
                                    <span class="status-badge @($"status-{entry.Status.ToLowerInvariant()}")">@entry.Status</span>
                                </td>
                                <td>@entry.CalculatedDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (entry.PaidDate.HasValue)
                                    {
                                        <span>@entry.PaidDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span style="color: #9ca3af;">&mdash;</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Ledger.TotalPages > 1)
            {
                <nav class="pager" aria-label="Ledger pagination">
                    <a class="@(Model.Ledger.HasPreviousPage ? "" : "disabled")"
                       asp-action="Ledger"
                       asp-route-agentId="@Model.AgentId"
                       asp-route-pageNumber="@(Model.Ledger.CurrentPage - 1)">
                        Prev
                    </a>

                    @for (var i = Math.Max(1, Model.Ledger.CurrentPage - 2); i <= Math.Min(Model.Ledger.TotalPages, Model.Ledger.CurrentPage + 2); i++)
                    {
                        if (i == Model.Ledger.CurrentPage)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a asp-action="Ledger" asp-route-agentId="@Model.AgentId" asp-route-pageNumber="@i">@i</a>
                        }
                    }

                    <a class="@(Model.Ledger.HasNextPage ? "" : "disabled")"
                       asp-action="Ledger"
                       asp-route-agentId="@Model.AgentId"
                       asp-route-pageNumber="@(Model.Ledger.CurrentPage + 1)">
                        Next
                    </a>
                </nav>
            }
        }
        else
        {
            <div style="padding: 3rem; text-align: center;">
                <p style="color: #9ca3af; font-size: 1rem;">No commission records found</p>
            </div>
        }
    </div>

    <div style="margin-top: 2rem;">
        <a href="@Url.Action("Index", "Dashboard")" style="background: var(--surface-container); color: var(--on-surface); padding: 1rem 2rem; border-radius: 0.5rem; font-weight: 600; text-decoration: none; display: inline-block;">
            &larr; Back to Dashboard
        </a>
    </div>
</div>
