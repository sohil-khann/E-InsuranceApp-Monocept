@model EInsurance.Models.Commission.CommissionCalculationInputViewModel

@{
    ViewData["Title"] = "Select Agent";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold">Commission Dashboard</h1>
        <p class="text-muted">Select an agent to view their commission details</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Dashboard" method="get">
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Select Agent</label>
                        <select name="agentId" class="form-select">
                            <option value="">-- Choose an Agent --</option>
                            @if (ViewBag.Agents != null)
                            {
                                @foreach (var agent in ViewBag.Agents)
                                {
                                    <option value="@agent.AgentId">@agent.FullName - @agent.Email</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-search me-2"></i>View Dashboard
                        </button>
                        <a asp-action="Calculator" class="btn btn-outline-success">
                            <i class="bi bi-calculator me-2"></i>Calculator
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Quick Stats</h5>
                @if (ViewBag.Agents != null)
                {
                    <p class="mb-2"><strong>Total Agents:</strong> @ViewBag.Agents.Count</p>
                }
                <p class="mb-0 text-muted small">Select an agent above to view their commission performance, recent disbursements, and monthly breakdown.</p>
            </div>
        </div>
    </div>
</div>