@model EInsurance.Models.Admin.ManageUsersViewModel

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1 class="h3 fw-bold">Manage Users</h1>
        <p class="text-muted">Manage your organization's users, agents, and employees</p>
    </div>
    <div class="col-md-4 text-md-end">
        <div class="btn-group">
            <a asp-controller="Registration" asp-action="RegisterEmployee" class="btn btn-success">
                <i class="bi bi-person-plus me-1"></i>New Employee
            </a>
            <a asp-controller="Registration" asp-action="RegisterInsuranceAgent" class="btn btn-outline-success">
                <i class="bi bi-person-plus me-1"></i>New Agent
            </a>
        </div>
    </div>
</div>

<form method="get" asp-action="ManageUsers" class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by name, email, or role..." value="@Model.SearchTerm" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-search me-1"></i>Search
                </button>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th>Agent</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No users found</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-success bg-opacity-10 rounded-circle p-2 me-3">
                                        <i class="bi bi-person text-success"></i>
                                    </div>
                                    <div>
                                        <p class="fw-semibold mb-0">@user.FullName</p>
                                        <p class="small text-muted mb-0">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-success bg-opacity-10 text-success">@user.Role</span>
                            </td>
                            <td>
                                @if (user.Role == "CUSTOMER")
                                {
                                    @if (!string.IsNullOrEmpty(user.AgentName))
                                    {
                                        <span class="badge bg-primary">@user.AgentName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No agent</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td>
                                @if (user.Status == "Active")
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@user.Status</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (user.Role == "CUSTOMER")
                                {
                                    <a asp-action="AssignAgent" asp-route-customerId="@user.Id" class="btn btn-sm btn-outline-primary" title="Assign Agent">
                                        <i class="bi bi-person-plus"></i>
                                    </a>
                                }
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-success" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.Users.Count > 0)
{
    <div class="mt-3 text-muted small">
        Showing @Model.Users.Count user(s)
    </div>
}