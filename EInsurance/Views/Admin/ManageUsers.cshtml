@model EInsurance.Models.Admin.ManageUsersViewModel

@{
    ViewData["Title"] = "Manage Users | Guardian Portal";
    Layout = null; // We are building a standalone-ish layout or using custom components
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        vertical-align: middle;
        }

        body {
        font-family: 'Inter', sans-serif;
        }

        .glass-panel {
        background: rgba(244, 251, 246, 0.7);
        backdrop-filter: blur(20px);
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "primary": "#006b54",
        "primary-container": "#22b590",
        "secondary": "#3a6757",
        "on-surface": "#171d1a",
        "on-surface-variant": "#3d4a44",
        "surface": "#f4fbf6",
        "surface-bright": "#f4fbf6",
        "surface-container-low": "#eff5f0",
        "surface-container-high": "#e3eae5",
        "surface-container-highest": "#dde4df",
        "surface-container-lowest": "#ffffff",
        "outline": "#6c7a74",
        "outline-variant": "#bbcac2",
        "error": "#ba1a1a",
        "error-container": "#ffdad6"
        }
        }
        }
        }
    </script>
</head>
<body class="bg-surface text-on-surface">
    <div class="flex min-h-screen">
        <!-- SideNavBar -->
        <aside class="hidden md:flex flex-col h-screen w-72 sticky top-0 bg-surface-container-low py-8 px-6 space-y-2">
            <div class="mb-10 px-4">
                <h2 class="text-lg font-bold text-primary">Guardian Portal</h2>
                <p class="text-xs uppercase tracking-widest text-secondary opacity-70">Veridian Protocol</p>
            </div>
            <nav class="flex-1 space-y-2">
                <a class="text-on-secondary-container hover:bg-surface-container-highest/40 transition-all duration-300 px-4 py-3 flex items-center gap-3 rounded-lg active:translate-x-1" asp-controller="Dashboard" asp-action="Index">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="font-sans text-sm tracking-tight">Dashboard</span>
                </a>
                <a class="bg-surface-container-highest text-primary font-semibold rounded-lg px-4 py-3 shadow-sm flex items-center gap-3 transition-all duration-300" href="#">
                    <span class="material-symbols-outlined">group</span>
                    <span class="font-sans text-sm tracking-tight">Manage Users</span>
                </a>
                <a class="text-on-secondary-container hover:bg-surface-container-highest/40 transition-all duration-300 px-4 py-3 flex items-center gap-3 rounded-lg active:translate-x-1" asp-controller="Policies" asp-action="CustomerPolicies">
                    <span class="material-symbols-outlined">description</span>
                    <span class="font-sans text-sm tracking-tight">Policies</span>
                </a>
            </nav>
            <form asp-controller="Account" asp-action="Logout" method="post" class="mt-auto">
                <button type="submit" class="w-full bg-surface-container-high text-on-surface py-3 px-6 rounded-lg font-sans text-sm tracking-tight flex items-center justify-center gap-2 hover:bg-surface-container-highest transition-colors">
                    <span class="material-symbols-outlined">logout</span>
                    Logout
                </button>
            </form>
        </aside>

        <div class="flex-1 flex flex-col min-w-0">
            <!-- TopNavBar -->
            <header class="w-full top-0 sticky z-30 bg-surface-bright flex justify-between items-center px-8 md:px-12 py-6">
                <div class="flex items-center gap-4">
                    <a asp-controller="Home" asp-action="Index" class="text-2xl font-black tracking-tighter text-primary no-underline">Guardian Insurance</a>
                </div>
                <div class="hidden lg:flex items-center space-x-8 font-sans font-medium text-sm tracking-tight">
                    <a class="text-secondary hover:text-primary-container transition-colors duration-200" href="#">Claims</a>
                    <a class="text-secondary hover:text-primary-container transition-colors duration-200" href="#">Policies</a>
                    <a class="text-secondary hover:text-primary-container transition-colors duration-200" href="#">Support</a>
                    <a class="text-secondary hover:text-primary-container transition-colors duration-200" href="#">Find Agent</a>
                </div>
                <div class="flex items-center gap-4">
                    <div class="relative hidden sm:block">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-outline material-symbols-outlined scale-75">search</span>
                        <input class="bg-surface-container-high border-none rounded-lg pl-10 pr-4 py-2 text-xs focus:ring-0 focus:border-none focus:outline-none placeholder:text-outline/60" placeholder="Global search..." type="text" />
                    </div>
                    <button class="text-primary active:scale-95 transition-transform duration-200">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    <button class="text-primary active:scale-95 transition-transform duration-200">
                        <span class="material-symbols-outlined">account_circle</span>
                    </button>
                </div>
            </header>

            <!-- Main Content -->
            <main class="flex-1 p-8 md:p-12 max-w-7xl w-full mx-auto">
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                    <div class="space-y-2">
                        <p class="text-xs font-bold tracking-widest uppercase text-secondary/60">Administration</p>
                        <h1 class="text-5xl font-black tracking-tight text-primary">Manage Users</h1>
                        <p class="text-on-surface-variant max-w-md">Orchestrate your organizational hierarchy and permission protocols through the Veridian secure access layer.</p>
                    </div>
                    <div class="flex gap-3">
                        <div class="relative group">
                            <button class="bg-gradient-to-br from-primary to-primary-container text-white px-8 py-4 rounded-lg font-bold tracking-tight shadow-lg shadow-primary/10 hover:shadow-primary/20 active:scale-95 transition-all duration-200 flex items-center gap-2" id="createUserBtn">
                                <span class="material-symbols-outlined">person_add</span>
                                Create New User
                            </button>
                            <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-xl border border-surface-container-high opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 overflow-hidden">
                                <a asp-controller="Registration" asp-action="RegisterEmployee" class="block px-6 py-4 text-sm font-bold text-on-surface hover:bg-surface-container-low transition-colors flex items-center gap-3">
                                    <span class="material-symbols-outlined text-primary">badge</span>
                                    New Employee
                                </a>
                                <a asp-controller="Registration" asp-action="RegisterInsuranceAgent" class="block px-6 py-4 text-sm font-bold text-on-surface hover:bg-surface-container-low transition-colors flex items-center gap-3 border-t border-surface-container-high">
                                    <span class="material-symbols-outlined text-primary">support_agent</span>
                                    New Agent
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filters & Stats Area -->
                <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
                    <div class="lg:col-span-3 bg-surface-container-low rounded-xl p-2 flex flex-col md:flex-row items-center gap-2">
                        <div class="relative flex-1 w-full">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-primary material-symbols-outlined">search</span>
                            <input class="w-full bg-transparent border-none py-4 pl-12 pr-4 focus:ring-0 text-sm placeholder:text-outline-variant font-medium" placeholder="Search by name, email, or role..." type="text" />
                        </div>
                        <div class="h-8 w-px bg-outline-variant/20 hidden md:block"></div>
                        <div class="flex items-center gap-2 p-2 w-full md:w-auto">
                            <button class="bg-surface-container-highest text-on-surface-variant px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider flex items-center gap-2 hover:bg-surface-container-high transition-colors">
                                <span class="material-symbols-outlined text-sm">filter_list</span>
                                Status: All
                            </button>
                            <button class="bg-surface-container-highest text-on-surface-variant px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider flex items-center gap-2 hover:bg-surface-container-high transition-colors">
                                <span class="material-symbols-outlined text-sm">tune</span>
                                Advanced
                            </button>
                        </div>
                    </div>
                    <div class="bg-secondary-container/30 rounded-xl p-6 flex flex-col justify-center">
                        <p class="text-xs font-bold text-on-secondary-container/60 uppercase mb-1">Total Licenses</p>
                        <div class="flex items-baseline gap-2">
                            <span class="text-3xl font-black text-primary">@Model.TotalLicenses</span>
                            <span class="text-xs font-medium text-secondary">/ @Model.MaxLicenses</span>
                        </div>
                    </div>
                </div>

                <!-- Table Area -->
                <div class="bg-surface-container-lowest rounded-xl overflow-hidden mb-8 shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-xs font-bold uppercase tracking-widest text-secondary">
                                    <th class="px-8 py-5">User Identity</th>
                                    <th class="px-8 py-5">Role Protocol</th>
                                    <th class="px-8 py-5">System Status</th>
                                    <th class="px-8 py-5 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-surface-container-low/50">
                                @foreach (var user in Model.Users)
                                {
                                    <tr class="group hover:bg-surface-container-low/30 transition-colors">
                                        <td class="px-8 py-6">
                                            <div class="flex items-center gap-4">
                                                <div class="w-12 h-12 rounded-full bg-primary-container/20 flex items-center justify-center font-bold text-primary">
                                                    @user.FullName.Substring(0, 1).ToUpper()
                                                </div>
                                                <div>
                                                    <p class="font-bold text-on-surface">@user.FullName</p>
                                                    <p class="text-xs text-on-surface-variant">@user.Email</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-8 py-6">
                                            <div class="inline-flex items-center gap-2 bg-surface-container-high px-3 py-1 rounded-full text-xs font-bold uppercase text-secondary">
                                                <span class="material-symbols-outlined text-sm">
                                                    @(user.Role == "SYSTEM ADMIN" ? "admin_panel_settings" : (user.Role == "AGENT" ? "person" : "badge"))
                                                </span>
                                                @user.Role
                                            </div>
                                        </td>
                                        <td class="px-8 py-6">
                                            <div class="flex items-center gap-2">
                                                <span class="w-2 h-2 rounded-full @(user.Status == "Active" ? "bg-primary" : (user.Status == "Revoked" ? "bg-error" : "bg-outline-variant"))"></span>
                                                <span class="text-sm font-medium @(user.Status == "Active" ? "text-primary" : (user.Status == "Revoked" ? "text-error" : "text-outline"))">@user.Status</span>
                                            </div>
                                        </td>
                                        <td class="px-8 py-6 text-right">
                                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                <a asp-action="EditUser" asp-route-id="@user.Id" class="w-10 h-10 rounded-lg hover:bg-primary-container/10 text-primary transition-colors flex items-center justify-center no-underline">
                                                    <span class="material-symbols-outlined">edit_square</span>
                                                </a>
                                                <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');" class="inline">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button type="submit" class="w-10 h-10 rounded-lg hover:bg-error-container/20 text-error transition-colors flex items-center justify-center">
                                                        <span class="material-symbols-outlined">delete</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Pagination Area -->
                <div class="flex flex-col sm:flex-row items-center justify-between gap-6 px-4">
                    <p class="text-xs font-bold uppercase tracking-widest text-secondary/60">Showing 1 to @Model.Users.Count of @Model.Users.Count users</p>
                    <div class="flex items-center gap-1">
                        <button class="w-10 h-10 rounded-lg flex items-center justify-center bg-surface-container-low text-secondary hover:bg-primary-container/20 transition-colors">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>
                        <button class="w-10 h-10 rounded-lg flex items-center justify-center bg-primary text-white font-bold text-xs shadow-md shadow-primary/20">1</button>
                        <button class="w-10 h-10 rounded-lg flex items-center justify-center bg-surface-container-low text-secondary hover:bg-primary-container/20 transition-colors active:scale-90">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                    </div>
                </div>
            </main>

            <!-- Footer -->
            <footer class="w-full mt-auto flex justify-between items-center px-16 py-12 bg-surface-container-highest">
                <div class="flex flex-col gap-2">
                    <span class="text-sm font-black text-primary">Guardian Insurance</span>
                    <p class="text-[10px] tracking-widest uppercase font-bold text-secondary opacity-60">© 2026 Guardian Insurance. All rights reserved.</p>
                </div>
                <div class="flex gap-8">
                    <a class="font-sans text-xs tracking-widest uppercase font-bold text-secondary hover:text-primary transition-all opacity-80 hover:opacity-100 no-underline" href="#">Privacy Policy</a>
                    <a class="font-sans text-xs tracking-widest uppercase font-bold text-secondary hover:text-primary transition-all opacity-80 hover:opacity-100 no-underline" href="#">Terms of Service</a>
                    <a class="font-sans text-xs tracking-widest uppercase font-bold text-secondary hover:text-primary transition-all opacity-80 hover:opacity-100 no-underline" href="#">Contact Support</a>
                </div>
            </footer>
        </div>
    </div>
</body>
</html>
