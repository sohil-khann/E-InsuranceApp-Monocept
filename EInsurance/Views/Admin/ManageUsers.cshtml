@model EInsurance.Models.Admin.ManageUsersViewModel

@{
    ViewData["Title"] = "Manage Users";
}

<div class="py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item text-uppercase small tracking-wider text-muted">Administration</li>
                </ol>
            </nav>
            <h1 class="display-5 fw-bold mb-2">Manage Users</h1>
            <p class="text-muted lead mb-0">Orchestrate your organizational hierarchy and permission protocols through the Veridian secure access layer.</p>
        </div>
        <div class="col-auto">
            <div class="dropdown">
                <button class="btn btn-success px-4 py-2 fw-semibold d-flex align-items-center gap-2 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-plus-fill"></i>
                    Create New User
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li><a class="dropdown-item py-2" asp-controller="Registration" asp-action="RegisterEmployee">New Employee</a></li>
                    <li><a class="dropdown-item py-2" asp-controller="Registration" asp-action="RegisterInsuranceAgent">New Insurance Agent</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-3 bg-light">
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" class="form-control border-0 bg-transparent" placeholder="Search by name, email, or role...">
                        </div>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-secondary border-0 bg-white shadow-sm px-3 d-flex align-items-center gap-2">
                            <i class="bi bi-filter"></i>
                            STATUS: ALL
                        </button>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-outline-secondary border-0 bg-white shadow-sm px-3 d-flex align-items-center gap-2">
                            <i class="bi bi-sliders"></i>
                            ADVANCED
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100" style="background-color: #e8f5f1;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase small tracking-wider text-muted fw-bold mb-1">Total Licenses</div>
                        <div class="display-5 fw-bold text-success">@Model.TotalLicenses <span class="fs-4 text-muted fw-normal">/ @Model.MaxLicenses</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small fw-bold text-muted border-bottom">
                    <tr>
                        <th class="px-4 py-3 border-0">User Identity</th>
                        <th class="px-4 py-3 border-0">Role Protocol</th>
                        <th class="px-4 py-3 border-0">System Status</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr class="border-bottom">
                            <td class="px-4 py-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle bg-dark text-white d-flex align-items-center justify-content-center fw-bold" style="width: 48px; height: 48px; border-radius: 50%; min-width: 48px;">
                                        @user.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="text-truncate" style="max-width: 250px;">
                                        <div class="fw-bold text-dark text-truncate">@user.FullName</div>
                                        <div class="small text-muted text-truncate">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-4">
                                <span class="badge rounded-pill px-3 py-2 text-dark bg-light border d-inline-flex align-items-center gap-2" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                                    <i class="bi bi-shield-lock-fill small text-muted"></i>
                                    @user.Role
                                </span>
                            </td>
                            <td class="px-4 py-4">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="status-indicator @(user.Status == "Active" ? "bg-success" : (user.Status == "Revoked" ? "bg-danger" : "bg-warning"))" style="width: 8px; height: 8px; border-radius: 50%;"></span>
                                    <span class="small fw-semibold">@user.Status</span>
                                </div>
                            </td>
                            <td class="px-4 py-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-outline-dark btn-sm border-0 rounded-circle" style="width: 32px; height: 32px; padding: 0; line-height: 32px;">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm border-0 rounded-circle" style="width: 32px; height: 32px; padding: 0; line-height: 32px;">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-3 bg-light border-top d-flex justify-content-between align-items-center">
            <div class="small text-muted">
                Showing 1 to @Model.Users.Count of @Model.Users.Count users
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item disabled"><a class="page-link bg-transparent" href="#"><i class="bi bi-chevron-left"></i></a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item disabled"><a class="page-link bg-transparent" href="#"><i class="bi bi-chevron-right"></i></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.1em; }
    .status-indicator { display: inline-block; }
    .table-hover tbody tr:hover { background-color: #f8f9fa; }
    .page-link { border: none; color: #6c757d; margin: 0 2px; border-radius: 4px !important; }
    .page-item.active .page-link { background-color: #006b5d; color: white; }
    .btn-success { background-color: #00a884; border-color: #00a884; }
    .btn-success:hover { background-color: #008f70; border-color: #008f70; }
    .avatar-circle { flex-shrink: 0; }
</style>
