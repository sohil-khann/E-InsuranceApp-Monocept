@model EInsurance.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <div class="auth-card">
            <div class="mb-4 text-center">
                <span class="eyebrow">Authentication</span>
                <h1 class="h3 mt-3">Sign in to EInsurance</h1>
                <p class="text-muted mb-0">Use your username or email with your password.</p>
            </div>

            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert alert-success">@successMessage</div>
            }

            <form asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Identifier" class="form-label"></label>
                    <input asp-for="Identifier" class="form-control form-control-lg" autocomplete="username" />
                    <span asp-validation-for="Identifier" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-dark w-100 btn-lg">Login</button>
            </form>

            <div class="demo-credentials mt-4">
                <h2 class="h6">Development credentials</h2>
                <p class="mb-1"><strong>Admin:</strong> <code>admin</code> / <code>Admin@123</code></p>
                <p class="mb-1"><strong>Employee:</strong> <code>employee</code> / <code>Employee@123</code></p>
                <p class="mb-1"><strong>Agent:</strong> <code>agent</code> / <code>Agent@123</code></p>
                <p class="mb-0"><strong>Customer:</strong> <code>customer@einsurance.local</code> / <code>Customer@123</code></p>
            </div>

            <div class="mt-4 text-center">
                <a asp-action="Register">New customer? Create an account</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
