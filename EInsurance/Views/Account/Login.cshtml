@model EInsurance.Models.Auth.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Guardian Insurance | Secure Login";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary-fixed-variant": "#00513e",
                        "surface-bright": "#f4fbf6",
                        "primary": "#006b54",
                        "primary-container": "#22b590",
                        "tertiary": "#9e4035",
                        "outline": "#6c7a74",
                        "inverse-on-surface": "#ecf2ed",
                        "on-error": "#ffffff",
                        "surface-container-high": "#e3eae5",
                        "on-surface": "#171d1a",
                        "error": "#ba1a1a",
                        "surface-container-lowest": "#ffffff",
                        "secondary-container": "#bcedd9",
                        "surface-container-highest": "#dde4df",
                        "on-secondary-fixed": "#002117",
                        "on-background": "#171d1a",
                        "on-error-container": "#93000a",
                        "background": "#f4fbf6",
                        "surface-dim": "#d5dcd7",
                        "on-surface-variant": "#3d4a44",
                        "on-secondary": "#ffffff",
                        "surface-container-low": "#eff5f0",
                        "tertiary-container": "#f28071",
                        "error-container": "#ffdad6",
                        "surface-variant": "#dde4df",
                        "inverse-surface": "#2b322f",
                        "secondary": "#3a6757",
                        "on-primary": "#ffffff",
                        "on-primary-container": "#004030",
                        "outline-variant": "#bbcac2",
                        "on-primary-fixed": "#002117",
                        "on-tertiary-fixed-variant": "#7f2920",
                        "surface-container": "#e9efea",
                        "primary-fixed": "#77f9d0",
                        "secondary-fixed": "#bcedd9",
                        "primary-fixed-dim": "#58dcb5",
                        "secondary-fixed-dim": "#a1d1be",
                        "on-secondary-fixed-variant": "#214f40",
                        "on-secondary-container": "#406d5d",
                        "on-tertiary": "#ffffff",
                        "surface": "#f4fbf6",
                        "inverse-primary": "#58dcb5",
                        "on-tertiary-container": "#6b1a13",
                        "surface-tint": "#006b54",
                        "tertiary-fixed-dim": "#ffb4a9"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        body {
            font-family: 'Inter', sans-serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
        }
    </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col">
    <main class="flex-grow flex items-center justify-center relative overflow-hidden px-6 py-12 md:py-24">
        <!-- Abstract Background Decorative Elements -->
        <div class="absolute top-[-10%] right-[-5%] w-[40rem] h-[40rem] rounded-full bg-primary-container/10 blur-3xl"></div>
        <div class="absolute bottom-[-15%] left-[-5%] w-[35rem] h-[35rem] rounded-full bg-primary/5 blur-3xl"></div>
        <div class="max-w-6xl w-full grid grid-cols-1 lg:grid-cols-12 gap-0 lg:gap-12 items-center relative z-10">
            <!-- Hero Content / Editorial Branding -->
            <div class="lg:col-span-7 mb-12 lg:mb-0">
                <div class="inline-flex items-center space-x-2 mb-8">
                    <div class="w-10 h-10 rounded bg-gradient-to-br from-primary to-primary-container flex items-center justify-center">
                        <span class="material-symbols-outlined text-white" data-icon="shield">shield</span>
                    </div>
                    <span class="text-2xl font-black tracking-tighter text-primary">Guardian Insurance</span>
                </div>
                <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-on-surface mb-6 leading-[1.1]">
                    Secure access to your <span class="text-primary-container">Veridian Protocol</span>.
                </h1>
                <p class="text-lg text-on-surface-variant max-w-lg font-medium leading-relaxed mb-8">
                    Manage your policies, process claims, and ensure your assets are protected under our precision-engineered security framework.
                </p>
                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center space-x-3 bg-surface-container-low px-4 py-2 rounded-lg">
                        <span class="material-symbols-outlined text-primary-container" data-icon="verified_user" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Auth Protocol</span>
                            <span class="text-sm font-bold text-primary">JWT Tokenized</span>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3 bg-surface-container-low px-4 py-2 rounded-lg">
                        <span class="material-symbols-outlined text-primary-container" data-icon="enhanced_encryption" style="font-variation-settings: 'FILL' 1;">enhanced_encryption</span>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Hashing Standard</span>
                            <span class="text-sm font-bold text-primary">Bcrypt Hash</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Login Card -->
            <div class="lg:col-span-5 flex justify-center lg:justify-end">
                <div class="w-full max-w-md bg-surface-container-lowest rounded-xl p-8 lg:p-10 shadow-[0_32px_64px_-16px_rgba(23,29,26,0.06)] relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-primary to-primary-container"></div>
                    <div class="mb-10">
                        <h2 class="text-2xl font-bold text-on-surface mb-2">Welcome Back</h2>
                        <p class="text-on-surface-variant text-sm font-medium">Please enter your credentials to proceed.</p>
                    </div>

                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6" role="alert">
                            <span class="block sm:inline">@successMessage</span>
                        </div>
                    }

                    <form asp-action="Login" method="post" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-medium mb-3"></div>

                        <!-- Username Field -->
                        <div class="relative group">
                            <label asp-for="Identifier" class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Username or Email</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 w-1 bg-transparent group-focus-within:bg-primary transition-colors duration-200"></div>
                                <input asp-for="Identifier" class="w-full bg-surface-container-high border-0 rounded-lg py-4 pl-6 pr-4 focus:ring-0 text-on-surface placeholder:text-outline-variant font-medium transition-all" placeholder="e.g. v.veridian" autocomplete="username" />
                            </div>
                            <span asp-validation-for="Identifier" class="text-red-500 text-[10px] font-bold mt-1 block"></span>
                        </div>

                        <!-- Password Field -->
                        <div class="relative group">
                            <div class="flex justify-between items-center mb-2">
                                <label asp-for="Password" class="block text-[10px] font-bold uppercase tracking-widest text-on-surface-variant ml-1">Password</label>
                                <a class="text-[10px] font-bold uppercase tracking-widest text-primary-container hover:text-primary transition-colors" href="#">Forgot Password?</a>
                            </div>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 w-1 bg-transparent group-focus-within:bg-primary transition-colors duration-200"></div>
                                <input asp-for="Password" class="w-full bg-surface-container-high border-0 rounded-lg py-4 pl-6 pr-12 focus:ring-0 text-on-surface placeholder:text-outline-variant font-medium transition-all" placeholder="••••••••" autocomplete="current-password" />
                                <button class="absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant hover:text-primary transition-colors" type="button" onclick="togglePasswordVisibility()">
                                    <span class="material-symbols-outlined text-xl" data-icon="visibility" id="password-toggle-icon">visibility</span>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-red-500 text-[10px] font-bold mt-1 block"></span>
                        </div>

                        <!-- Login Button -->
                        <button type="submit" class="w-full py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-lg shadow-lg hover:shadow-primary/20 active:scale-[0.98] transition-all duration-200 uppercase tracking-widest text-sm">
                            Access Portal
                        </button>
                    </form>

                    <div class="mt-8 pt-6 border-t border-surface-container flex flex-col items-center">
                        <p class="text-xs text-on-surface-variant font-medium mb-4">New customer? <a asp-action="Register" class="text-primary-container hover:text-primary font-bold">Create an account</a></p>
                        <div class="flex space-x-6">
                            <div class="flex items-center text-[10px] font-bold text-primary uppercase tracking-widest">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary-container mr-2"></span>
                                JWT Active
                            </div>
                            <div class="flex items-center text-[10px] font-bold text-primary uppercase tracking-widest">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary-container mr-2"></span>
                                SSL Encrypted
                            </div>
                        </div>
                    </div>

                    <!-- Development Credentials (Keep them for now but styled nicely) -->
                    <div class="mt-8 p-4 bg-surface-container-low rounded-lg text-[10px] font-medium text-on-surface-variant">
                        <p class="font-bold uppercase tracking-widest mb-2 border-b border-outline-variant/20 pb-1">Development Credentials</p>
                        <p><strong>Admin:</strong> admin / Admin@123</p>
                        <p><strong>Employee:</strong> employee / Employee@123</p>
                        <p><strong>Agent:</strong> agent / Agent@123</p>
                        <p><strong>Customer:</strong> customer@einsurance.local / Customer@123</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <!-- Footer Component -->
    <footer class="flex flex-col md:flex-row justify-between items-center px-6 md:px-16 py-12 w-full bg-surface-variant dark:bg-emerald-950 mt-auto">
        <div class="flex flex-col space-y-2 mb-6 md:mb-0">
            <span class="text-sm font-black text-primary dark:text-emerald-400">Guardian Insurance</span>
            <span class="font-sans text-[10px] tracking-widest uppercase font-bold text-on-secondary-container dark:text-emerald-400/50">© 2026 Guardian Insurance. All rights reserved.</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-6 md:space-x-8">
            <a class="font-sans text-[10px] tracking-widest uppercase font-bold text-on-secondary-container dark:text-emerald-400/50 hover:text-primary-container transition-all opacity-80 hover:opacity-100" href="#">Privacy Policy</a>
            <a class="font-sans text-[10px] tracking-widest uppercase font-bold text-on-secondary-container dark:text-emerald-400/50 hover:text-primary-container transition-all opacity-80 hover:opacity-100" href="#">Terms of Service</a>
            <a class="font-sans text-[10px] tracking-widest uppercase font-bold text-on-secondary-container dark:text-emerald-400/50 hover:text-primary-container transition-all opacity-80 hover:opacity-100" href="#">Accessibility</a>
            <a class="font-sans text-[10px] tracking-widest uppercase font-bold text-on-secondary-container dark:text-emerald-400/50 hover:text-primary-container transition-all opacity-80 hover:opacity-100" href="#">Contact Support</a>
        </nav>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.querySelector('input[type="password"]');
            const icon = document.getElementById('password-toggle-icon');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                passwordInput.type = 'password';
                icon.textContent = 'visibility';
            }
        }
    </script>
</body>
</html>
