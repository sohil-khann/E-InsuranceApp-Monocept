@model EInsurance.Models.Auth.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EInsurance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Inter', sans-serif;
                background: linear-gradient(135deg, #eef2f7 0%, #e6f4f1 100%);
                min-height: 100vh;
            }

            .left-section h1 {
                font-size: 3rem;
                font-weight: 700;
            }

            .highlight {
                color: #1aa37a;
            }

            .login-card {
                background: #ffffff;
                border-radius: 16px;
                padding: 40px;
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            }

            .form-control {
                height: 50px;
                border-radius: 10px;
            }

            .btn-primary {
                background: linear-gradient(135deg, #006b54, #1aa37a);
                border: none;
                height: 50px;
                border-radius: 10px;
                font-weight: 600;
            }

                .btn-primary:hover {
                    opacity: 0.9;
                }

            .small-text {
                font-size: 0.9rem;
            }
    </style>
</head>

<body class="d-flex align-items-center">

    <div class="container">
        <div class="row align-items-center">

            <!-- LEFT SIDE -->
            <div class="col-lg-6 d-none d-lg-block left-section">
                <h1>
                    Secure access to your
                    <span class="highlight">EInsurance Portal</span>
                </h1>

                <p class="mt-3 text-muted">
                    Manage your policies and access your account securely.
                </p>
            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-5 offset-lg-1 col-md-8 mx-auto">
                <div class="login-card">

                    <h4 class="fw-bold mb-2">Welcome Back</h4>
                    <p class="text-muted small-text mb-4">
                        Please enter your credentials to continue
                    </p>

                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert alert-success">@successMessage</div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Identifier" class="form-label fw-semibold">Username or Email</label>
                            <input asp-for="Identifier" class="form-control" placeholder="Enter your username or email" />
                            <span asp-validation-for="Identifier" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Login
                        </button>
                    </form>

                    <div class="text-center mt-4 small-text">
                        <span class="text-muted">New user?</span>
                        <a asp-action="Register" class="fw-semibold text-decoration-none ms-1">Create account</a>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>