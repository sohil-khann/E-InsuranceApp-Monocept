@model EInsurance.Models.Auth.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EInsurance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
            min-height: 100vh;
        }
        .login-card {
            max-width: 420px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
        .brand-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #006b54 0%, #22b590 100%);
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="login-card card shadow-lg border-0 rounded-4 p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="brand-icon rounded-3 d-inline-flex align-items-center justify-content-center mb-3">
                            <i class="bi bi-shield-check text-white fs-4"></i>
                        </div>
                        <h1 class="h3 fw-bold text-dark">EInsurance</h1>
                        <p class="text-muted">Sign in to your account</p>
                    </div>

                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert alert-success d-flex align-items-center" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @successMessage
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Identifier" class="form-label fw-semibold">Username or Email</label>
                            <input asp-for="Identifier" class="form-control form-control-lg" placeholder="Enter your username or email" />
                            <span asp-validation-for="Identifier" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 btn-lg fw-semibold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small">New customer? <a asp-action="Register" class="text-success fw-semibold">Create an account</a></p>
                    </div>

                    <hr class="my-4">

                    <div class="bg-light rounded-3 p-3 small">
                        <p class="fw-bold mb-2">Demo Credentials:</p>
                        <p class="mb-1"><strong>Admin:</strong> admin / Admin@123</p>
                        <p class="mb-1"><strong>Employee:</strong> employee / Employee@123</p>
                        <p class="mb-1"><strong>Agent:</strong> agent / Agent@123</p>
                        <p class="mb-0"><strong>Customer:</strong> customer@einsurance.local / Customer@123</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>