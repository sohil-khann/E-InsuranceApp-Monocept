@model EInsurance.Models.Auth.CustomerRegistrationViewModel

@{
    Layout = null;
    ViewData["Title"] = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EInsurance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Inter', sans-serif;
                background: linear-gradient(135deg, #eef2f7 0%, #e6f4f1 100%);
                min-height: 100vh;
            }

            .left-section h1 {
                font-size: 2.8rem;
                font-weight: 700;
            }

            .highlight {
                color: #1aa37a;
            }

            .register-card {
                background: #ffffff;
                border-radius: 16px;
                padding: 40px;
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            }

            .form-control, .form-select {
                height: 50px;
                border-radius: 10px;
            }

            .btn-primary {
                background: linear-gradient(135deg, #006b54, #1aa37a);
                border: none;
                height: 50px;
                border-radius: 10px;
                font-weight: 600;
            }

            .btn-outline-secondary {
                height: 50px;
                border-radius: 10px;
            }

            .btn-primary:hover {
                opacity: 0.9;
            }

            .small-text {
                font-size: 0.9rem;
            }
    </style>
</head>

<body class="d-flex align-items-center">

    <div class="container">
        <div class="row align-items-center">

            <!-- LEFT SIDE -->
            <div class="col-lg-6 d-none d-lg-block left-section">
                <h1>
                    Create your
                    <span class="highlight">EInsurance Account</span>
                </h1>

                <p class="mt-3 text-muted">
                    Get started by creating your account and managing your insurance digitally.
                </p>
            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-6 col-md-10 mx-auto">
                <div class="register-card">

                    <h4 class="fw-bold mb-2">Register</h4>
                    <p class="text-muted small-text mb-4">
                        Fill in your details to create an account
                    </p>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row g-3">

                            <div class="col-md-6">
                                <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <input asp-for="Email" type="email" class="form-control" placeholder="Email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <input asp-for="Phone" class="form-control" placeholder="Phone Number" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <select asp-for="AgentId" asp-items="ViewBag.AgentList" class="form-select">
                                    <option value="">Select Agent (Optional)</option>
                                </select>
                                <span asp-validation-for="AgentId" class="text-danger small"></span>
                            </div>

                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <a asp-action="Login" class="btn btn-outline-secondary w-50">Back</a>
                            <button type="submit" class="btn btn-primary w-50">
                                Create Account
                            </button>
                        </div>

                    </form>

                    <div class="text-center mt-4 small-text">
                        <span class="text-muted">Already have an account?</span>
                        <a asp-action="Login" class="fw-semibold text-decoration-none ms-1">Sign in</a>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>