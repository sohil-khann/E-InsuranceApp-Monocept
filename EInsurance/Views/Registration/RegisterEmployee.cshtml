@model EInsurance.Models.Auth.EmployeeRegistrationViewModel

@{
    ViewData["Title"] = "Guardian Insurance | Register Employee";
}

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item text-uppercase small tracking-wider text-muted">Administration</li>
                </ol>
            </nav>
            <h1 class="display-5 fw-bold mb-2">Register Employee</h1>
            <p class="text-muted lead mb-0">Provision new internal employee credentials with specific role protocols.</p>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-secondary px-4 py-2 fw-semibold d-flex align-items-center gap-2" asp-controller="Admin" asp-action="ManageUsers">
                <i class="bi bi-arrow-left"></i>
                Back to Users
            </a>
        </div>
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-sm overflow-hidden position-relative">
                <div class="position-absolute top-0 start-0 w-100" style="height: 4px; background: linear-gradient(90deg, #006b54 0%, #22b590 100%); z-index: 10;"></div>
                <div class="card-body p-5">
                    <div class="row g-5">
                        <div class="col-lg-4 border-end d-none d-lg-block">
                            <div class="d-flex flex-column gap-4">
                                <div class="bg-light p-4 rounded-3 mb-4">
                                    <div class="text-uppercase small tracking-wider text-muted fw-bold mb-2">Protocol</div>
                                    <div class="d-flex align-items-center gap-2 text-primary fw-bold">
                                        <i class="bi bi-person-badge-fill"></i>
                                        INTERNAL_STAFF
                                    </div>
                                </div>
                                <div class="bg-light p-4 rounded-3">
                                    <div class="text-uppercase small tracking-wider text-muted fw-bold mb-2">Security</div>
                                    <div class="d-flex align-items-center gap-2 text-primary fw-bold small">
                                        <i class="bi bi-lock-fill"></i>
                                        BCRYPT_ENCRYPTED
                                    </div>
                                </div>
                                <div class="mt-4 p-2">
                                    <p class="small text-muted">Employees will have access to internal tools based on the role protocol assigned during registration.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-8">
                            <h2 class="h4 fw-bold mb-4">Employee Credentials</h2>
                            
                            @if (TempData["SuccessMessage"] is string successMessage)
                            {
                                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    @successMessage
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <form asp-action="RegisterEmployee" method="post" class="needs-validation" novalidate>
                                @Html.AntiForgeryToken()
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                                <div class="row g-4">
                                    <div class="col-12">
                                        <label asp-for="FullName" class="form-label small text-uppercase fw-bold tracking-wider text-muted"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-person text-muted"></i></span>
                                            <input asp-for="FullName" class="form-control bg-light border-0 py-2" placeholder="Full legal name" />
                                        </div>
                                        <span asp-validation-for="FullName" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="Email" class="form-label small text-uppercase fw-bold tracking-wider text-muted"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-envelope text-muted"></i></span>
                                            <input asp-for="Email" class="form-control bg-light border-0 py-2" placeholder="staff@guardian.io" />
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="Username" class="form-label small text-uppercase fw-bold tracking-wider text-muted"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-at text-muted"></i></span>
                                            <input asp-for="Username" class="form-control bg-light border-0 py-2" placeholder="v.staff" />
                                        </div>
                                        <span asp-validation-for="Username" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12">
                                        <label asp-for="Role" class="form-label small text-uppercase fw-bold tracking-wider text-muted"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-shield-shaded text-muted"></i></span>
                                            <input asp-for="Role" class="form-control bg-light border-0 py-2" placeholder="Operations, Claims, Support..." />
                                        </div>
                                        <span asp-validation-for="Role" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="Password" class="form-label small text-uppercase fw-bold tracking-wider text-muted"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-key text-muted"></i></span>
                                            <input asp-for="Password" type="password" class="form-control bg-light border-0 py-2" placeholder="••••••••" />
                                        </div>
                                        <span asp-validation-for="Password" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="ConfirmPassword" class="form-label small text-uppercase fw-bold tracking-wider text-muted"></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-check2-circle text-muted"></i></span>
                                            <input asp-for="ConfirmPassword" type="password" class="form-control bg-light border-0 py-2" placeholder="••••••••" />
                                        </div>
                                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mt-5 d-grid">
                                    <button type="submit" class="btn btn-dark py-3 fw-bold text-uppercase tracking-widest shadow-sm">
                                        Access Provisioned Employee
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.1em; }
    .tracking-widest { letter-spacing: 0.2em; }
    .btn-dark { background-color: #004030; border-color: #004030; }
    .btn-dark:hover { background-color: #002117; border-color: #002117; }
    .form-control:focus { background-color: #fff !important; box-shadow: 0 0 0 0.25rem rgba(0, 64, 48, 0.1); }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
