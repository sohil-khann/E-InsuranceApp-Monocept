@model IEnumerable<EInsurance.Domain.Entities.Payment>

@{
    ViewData["Title"] = "Payment History";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold">Payment History</h1>
        <p class="text-muted">View and download your payment receipts</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No payments found.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Receipt No</th>
                        <th>Policy</th>
                        <th>Plan</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th class="text-end">Receipt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold">#@payment.PaymentId</span>
                            </td>
                            <td>
                                <span class="badge bg-primary">POL-@payment.PolicyId.ToString("D6")</span>
                            </td>
                            <td>@payment.Policy.Scheme?.SchemeName</td>
                            <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-bold">₹@payment.Amount.ToString("N2")</td>
                            <td class="text-end">
                                <a asp-controller="Payment" asp-action="DownloadReceipt" asp-route-paymentId="@payment.PaymentId" class="btn btn-sm btn-success" title="Download Receipt">
                                    <i class="bi bi-download"></i> Download
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}