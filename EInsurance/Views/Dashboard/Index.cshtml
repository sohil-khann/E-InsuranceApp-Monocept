@model EInsurance.Models.DashboardViewModel
@using EInsurance.Security

@{
    ViewData["Title"] = "Dashboard";
    var isCustomer = Model.Role == RoleNames.Customer;
    var isAdmin = Model.Role == RoleNames.Admin;
    var isEmployee = Model.Role == RoleNames.Employee;
    Layout = "_Layout";
}

<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EInsurance | @ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
    </style>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#006b54",
                        "primary-container": "#22b590",
                        "tertiary": "#9e4035",
                        "outline": "#6c7a74",
                        "on-surface": "#171d1a",
                        "on-surface-variant": "#3d4a44",
                        "surface-container-low": "#eff5f0",
                        "surface-container-high": "#e3eae5",
                        "surface-container-highest": "#dde4df",
                        "surface-container-lowest": "#ffffff",
                        "surface": "#f4fbf6",
                        "secondary": "#3a6757",
                        "on-primary": "#ffffff"
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col">

    <nav class="w-full top-0 sticky z-50 bg-surface-container-low flex justify-between items-center px-8 py-4">
        
        <div class="hidden lg:flex items-center space-x-6 font-medium text-sm">
            <a asp-controller="Policies" asp-action="MyPolicies" class="text-secondary hover:text-primary transition-colors">My Policies</a>
            @if (isCustomer)
            {
                <a asp-controller="PolicyPurchase" asp-action="AvailableSchemes" class="text-secondary hover:text-primary transition-colors">Purchase Policy</a>
                <a asp-controller="Payment" asp-action="PaymentHistory" class="text-secondary hover:text-primary transition-colors">Payment History</a>
            }
        </div>
        <div class="flex items-center gap-4">
            <span class="text-sm text-muted">@User.Identity?.Name</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                <button type="submit" class="text-sm text-secondary hover:text-primary transition-colors flex items-center gap-1">
                    <span class="material-symbols-outlined text-lg">logout</span>
                    Logout
                </button>
            </form>
        </div>
    </nav>

    <main class="flex-1 p-8 md:p-12 max-w-7xl w-full mx-auto">
        <header class="mb-10">
            <p class="text-xs font-bold tracking-widest uppercase text-primary-container mb-2">Dashboard</p>
            <h1 class="text-4xl font-black tracking-tight text-on-surface mb-2">Welcome back, @Model.DisplayName</h1>
            <p class="text-on-surface-variant text-lg">@Model.Message</p>
        </header>

        @if (isCustomer)
        {
            <section class="space-y-6">
                <div class="flex justify-between items-center">
                    <h2 class="text-2xl font-bold tracking-tight text-on-surface">Quick Actions</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm">
                        <div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-primary">description</span>
                        </div>
                        <h3 class="text-lg font-bold text-on-surface mb-2">My Policies</h3>
                        <p class="text-sm text-on-surface-variant mb-4">View all your active policies, payment history, and coverage details.</p>
                        <a asp-controller="Policies" asp-action="MyPolicies" class="text-primary font-semibold text-sm hover:underline">View Policies</a>
                    </div>
                    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm">
                        <div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-primary">add_circle</span>
                        </div>
                        <h3 class="text-lg font-bold text-on-surface mb-2">Purchase New Policy</h3>
                        <p class="text-sm text-on-surface-variant mb-4">Browse available insurance schemes and secure your future.</p>
                        <a asp-controller="PolicyPurchase" asp-action="AvailableSchemes" class="text-primary font-semibold text-sm hover:underline">Browse Schemes</a>
                    </div>
                </div>
            </section>
        }
        else if (isAdmin || isEmployee)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @if (isAdmin)
                {
                    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm">
                        <div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-primary">group</span>
                        </div>
                        <h3 class="text-lg font-bold text-on-surface mb-2">Manage Users</h3>
                        <p class="text-sm text-on-surface-variant mb-4">Manage customers, agents, and employees.</p>
                        <a asp-controller="Admin" asp-action="ManageUsers" class="text-primary font-semibold text-sm hover:underline">Manage Users</a>
                    </div>
                    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm">
                        <div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-primary">description</span>
                        </div>
                        <h3 class="text-lg font-bold text-on-surface mb-2">Customer Policies</h3>
                        <p class="text-sm text-on-surface-variant mb-4">Search and review policy details.</p>
                        <a asp-controller="Policies" asp-action="CustomerPolicies" class="text-primary font-semibold text-sm hover:underline">View Policies</a>
                    </div>
                }
                @if (isAdmin || isEmployee)
                {
                    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm">
                        <div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-primary">person_add</span>
                        </div>
                        <h3 class="text-lg font-bold text-on-surface mb-2">Register Agent</h3>
                        <p class="text-sm text-on-surface-variant mb-4">Create insurance agent accounts.</p>
                        <a asp-controller="Registration" asp-action="RegisterInsuranceAgent" class="text-primary font-semibold text-sm hover:underline">Register Agent</a>
                    </div>
                }
                @if (isAdmin)
                {
                    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm">
                        <div class="w-12 h-12 bg-primary-container/20 rounded-lg flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-primary">badge</span>
                        </div>
                        <h3 class="text-lg font-bold text-on-surface mb-2">Register Employee</h3>
                        <p class="text-sm text-on-surface-variant mb-4">Create employee accounts.</p>
                        <a asp-controller="Registration" asp-action="RegisterEmployee" class="text-primary font-semibold text-sm hover:underline">Register Employee</a>
                    </div>
                }
            </div>
        }
    </main>

   
</body>
</html>