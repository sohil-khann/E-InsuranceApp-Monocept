@{
    ViewData["Title"] = "Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - EInsurance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
            min-height: 100vh;
        }
        .hero-section {
            background: linear-gradient(135deg, #006b54 0%, #22b590 100%);
        }
        .feature-card {
            transition: transform 0.2s ease;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shield-check me-2"></i>EInsurance
            </a>
            <div class="d-flex gap-2">
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success">Login</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-success">Register</a>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        <section class="hero-section text-white py-5">
            <div class="container py-5">
                <div class="row align-items-center">
                    <div class="col-lg-6">
                        <h1 class="display-4 fw-bold mb-4">Insurance Made Simple</h1>
                        <p class="lead mb-4 opacity-75">Protect your future with comprehensive insurance plans. Easy to purchase, simple to manage, and always there when you need it.</p>
                        <div class="d-flex gap-3">
                            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg fw-semibold">Get Started</a>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg">Sign In</a>
                        </div>
                    </div>
                    <div class="col-lg-6 text-center mt-4 mt-lg-0">
                        <i class="bi bi-shield-check display-1 opacity-75"></i>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-5">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="fw-bold text-dark">Why Choose EInsurance?</h2>
                    <p class="text-muted">We make insurance simple, transparent, and accessible</p>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card feature-card h-100 border-0 shadow-sm p-4">
                            <div class="bg-success bg-opacity-10 rounded-3 p-3 d-inline-flex mb-3">
                                <i class="bi bi-shield-check fs-3 text-success"></i>
                            </div>
                            <h4 class="fw-bold">Secure Coverage</h4>
                            <p class="text-muted">Comprehensive protection for you and your family with reliable coverage options.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card feature-card h-100 border-0 shadow-sm p-4">
                            <div class="bg-success bg-opacity-10 rounded-3 p-3 d-inline-flex mb-3">
                                <i class="bi bi-currency-dollar fs-3 text-success"></i>
                            </div>
                            <h4 class="fw-bold">Affordable Plans</h4>
                            <p class="text-muted">Flexible payment options and competitive premiums that fit your budget.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card feature-card h-100 border-0 shadow-sm p-4">
                            <div class="bg-success bg-opacity-10 rounded-3 p-3 d-inline-flex mb-3">
                                <i class="bi bi-headset fs-3 text-success"></i>
                            </div>
                            <h4 class="fw-bold">24/7 Support</h4>
                            <p class="text-muted">Dedicated support team available around the clock to assist you.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-5 bg-light">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="fw-bold text-dark">Insurance Plans</h2>
                    <p class="text-muted">Choose from our range of coverage options</p>
                </div>
                <div class="row g-4 justify-content-center">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center py-4">
                                <i class="bi bi-house fs-1 text-success mb-3"></i>
                                <h4 class="fw-bold">Home Insurance</h4>
                                <p class="text-muted">Protect your home and belongings with comprehensive coverage.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center py-4">
                                <i class="bi bi-car-front fs-1 text-success mb-3"></i>
                                <h4 class="fw-bold">Auto Insurance</h4>
                                <p class="text-muted">Coverage that keeps you and your vehicle protected on the road.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center py-4">
                                <i class="bi bi-heart-pulse fs-1 text-success mb-3"></i>
                                <h4 class="fw-bold">Life Insurance</h4>
                                <p class="text-muted">Secure your family's future with our life insurance plans.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0 small">&copy; 2026 EInsurance. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none small me-3">Privacy</a>
                    <a href="#" class="text-white-50 text-decoration-none small">Terms</a>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>