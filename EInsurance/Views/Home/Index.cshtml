@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-card text-center">
    <span class="eyebrow">Online Insurance Management System</span>
    <h1 class="display-5 fw-semibold mt-3">Secure policy operations for every role</h1>
    <p class="lead mt-3">
        Customers, admins, agents, and employees can sign in through the same portal and reach role-based access after JWT authentication.
    </p>
    <div class="mt-4 d-flex flex-column flex-sm-row justify-content-center gap-3">
        <a class="btn btn-dark btn-lg px-4" asp-controller="Account" asp-action="Login">Go to Login</a>
        <a class="btn btn-outline-dark btn-lg px-4" asp-controller="Account" asp-action="Register">Customer Sign Up</a>
        <a class="btn btn-outline-dark btn-lg px-4" asp-controller="Dashboard" asp-action="Index">Open Dashboard</a>
    </div>
</div>
