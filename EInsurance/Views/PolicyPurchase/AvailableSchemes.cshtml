@model EInsurance.Models.Policies.AvailableSchemesViewModel

@{
    ViewData["Title"] = "Available Schemes";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 fw-bold">Available Schemes</h1>
        <p class="text-muted">Browse and purchase insurance schemes</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var scheme in Model.Schemes)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3 d-inline-flex mb-3">
                        <i class="bi bi-shield-check fs-4 text-success"></i>
                    </div>
                    <span class="badge bg-success bg-opacity-10 text-success mb-2 d-block">@scheme.PlanName</span>
                    <h4 class="fw-bold mb-2">@scheme.SchemeName</h4>
                    <p class="text-muted small mb-3">@scheme.SchemeDetails</p>
                    <div class="mb-3">
                        <span class="text-muted small">Starts from</span>
                        <span class="h4 fw-bold text-success">$@scheme.BasePremium<small>/mo</small></span>
                    </div>
                    <a asp-action="CalculatePremium" asp-route-schemeId="@scheme.SchemeId" class="btn btn-success w-100">
                        <i class="bi bi-calculator me-2"></i>Calculate Premium
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Schemes.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No insurance schemes available at the moment.
    </div>
}