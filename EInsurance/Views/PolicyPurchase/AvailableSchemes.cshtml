@model EInsurance.Models.Policies.AvailableSchemesViewModel

@{
    ViewData["Title"] = "Available Schemes | Guardian Portal";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        body { font-family: 'Inter', sans-serif; }
        .btn-primary-gradient {
            background: linear-gradient(135deg, #006b54 0%, #22b590 100%);
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
          theme: {
            extend: {
              "colors": {
                      "primary": "#006b54",
                      "primary-container": "#22b590",
                      "secondary": "#3a6757",
                      "surface": "#f4fbf6",
                      "surface-bright": "#f4fbf6",
                      "surface-container-low": "#eff5f0",
                      "surface-container-high": "#e3eae5",
                      "surface-container-highest": "#dde4df",
                      "surface-container-lowest": "#ffffff"
              }
            }
          }
        }
    </script>
</head>
<body class="bg-surface text-on-surface">
    <div class="flex min-h-screen">
        
        <main class="flex-1 p-8 md:p-16 max-w-7xl w-full mx-auto space-y-12">
            <!-- Hero Section -->
            <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
                <div class="lg:col-span-7 space-y-6">
                    <span class="uppercase tracking-widest text-primary font-bold text-xs">Protection tailored for you</span>
                    <h2 class="text-6xl font-black tracking-tighter leading-[1.1] text-on-surface">Secure your future with <span class="text-primary-container">precision</span>.</h2>
                    <p class="text-on-surface-variant text-lg leading-relaxed max-w-xl">Explore our curated selection of insurance schemes designed with the Veridian protocol.</p>
                </div>
            </section>

            <!-- Insurance Grid -->
            <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var scheme in Model.Schemes)
                {
                    <div class="bg-surface-container-lowest rounded-2xl p-8 space-y-8 flex flex-col shadow-sm hover:shadow-xl transition-all duration-300 group">
                        <div class="bg-primary/5 w-14 h-14 rounded-2xl flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">shield</span>
                        </div>
                        <div class="flex-1">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-2">@scheme.PlanName</p>
                            <h3 class="text-xl font-bold tracking-tight mb-3">@scheme.SchemeName</h3>
                            <p class="text-on-surface-variant text-sm leading-relaxed">@scheme.SchemeDetails</p>
                        </div>
                        <div class="pt-6 border-t border-surface-container-high">
                            <div class="flex justify-between items-baseline mb-6">
                                <span class="text-xs font-bold uppercase tracking-widest text-on-surface-variant/60">Starts from</span>
                                <span class="text-2xl font-black text-primary">$@scheme.BasePremium<span class="text-xs font-medium text-on-surface-variant">/mo</span></span>
                            </div>
                            <a asp-action="CalculatePremium" asp-route-schemeId="@scheme.SchemeId" class="w-full py-4 rounded-xl btn-primary-gradient text-white font-bold text-sm hover:brightness-110 shadow-lg shadow-primary/10 transition-all text-center block no-underline">
                                Calculate Premium
                            </a>
                        </div>
                    </div>
                }
            </section>
        </main>
    </div>
</body>
</html>
